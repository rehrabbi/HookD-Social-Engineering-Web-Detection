# Copy this file to ".env" and adjust as needed. NEVER commit the real .env.

# Flask session signing key -- use a long random string
SECRET_KEY=change-me-to-a-long-random-string

# 1 = skip login (instant guest demo); 0 = require local accounts (default)
DEV_MODE=0

# Flask debug -- keep 0 unless actively debugging locally
FLASK_DEBUG=0

# Port the local server listens on (optional; defaults to 5000)
PORT=5000

# Where the local SQLite database file lives (optional; defaults to ./hookd.db)
DATABASE_PATH=

# Optional: explicit path to the Tesseract binary.
# Leave empty on Linux (found on PATH). On Windows it auto-detects
# C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
